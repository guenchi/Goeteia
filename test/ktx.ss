(define ABASE2 40960)
(let put ((bs aktx-bytes) (i 0))
  (when (pair? bs)
    (%mem-u8-set! (+ ABASE2 i) (car bs))
    (put (cdr bs) (+ i 1))))
(define ak (ktx-parse ABASE2 aktx-len))
(define alpha-ok
  (and (ktx-alpha? ak)
       (not (ktx-alpha? k))
       (begin
         (ktx-transcode! ak 0 DST 'rgba)
         (let loop ((gs golden-argba) (i 0) (bad 0))
           (if (null? gs)
               (begin
                 (when (> bad 0)
                   (display "alpha rgba: ") (display bad)
                   (display " bytes differ") (newline))
                 (= bad 0))
               (loop (cdr gs) (+ i 1)
                     (if (= (%mem-u8-ref (+ DST i)) (car gs))
                         bad
                         (+ bad 1))))))))

(and container-ok rgba-ok etc1-ok bc1-ok alpha-ok)
