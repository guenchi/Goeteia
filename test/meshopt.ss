;; expect: #t
;; (gfx meshopt): meshoptimizer vertex/index codecs + filters,
;; byte-for-byte against the reference decoder on gltfpack output.
(import (rnrs) (gfx meshopt))

;; golden meshopt data (chunked so the self-host reader stays shallow)
