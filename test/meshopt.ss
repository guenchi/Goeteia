(define bv2-mode (quote triangles))
(define bv2-filter (quote none))
(define bv2-stride 2)
(define bv2-count 36)
(define bv2-comp
  (append
   (quote (225 240 16 240 16 240 16 240 16 240 16 240 16 0 118 135 86 103 120 169 134 101 137 104 152 1 105 0 0))))
(define bv2-gold
  (append
   (quote (0 0 1 0 2 0 2 0 1 0 3 0 4 0 5 0 6 0 6 0 5 0 7 0 8 0 9 0 10 0 10 0 9 0 11 0 12 0 13 0 14 0 14 0 13 0 15 0 16 0 17 0 18 0 18 0 17 0 19 0 20 0 21 0 22 0 22 0 21 0 23 0))))


(define SRC 8192)
(define DST 16384)
(define (load! base bs)
  (let put ((b bs) (i 0))
    (when (pair? b) (%mem-u8-set! (+ base i) (car b)) (put (cdr b) (+ i 1)))))
(define (check-dec gold)
  (let loop ((g gold) (i 0) (bad 0))
    (if (null? g)
        (begin (when (> bad 0) (display "  ") (display bad)
                     (display " bytes differ") (newline))
               (= bad 0))
        (loop (cdr g) (+ i 1)
              (if (= (%mem-u8-ref (+ DST i)) (car g)) bad (+ bad 1))))))
(define (llen l) (let loop ((l l) (n 0)) (if (null? l) n (loop (cdr l) (+ n 1)))))

(load! SRC bv1-comp)
(meshopt-vertex! SRC (llen bv1-comp) DST bv1-count bv1-stride)
(define vertex-ok (check-dec bv1-gold))

(load! SRC bv2-comp)
(meshopt-index! SRC (llen bv2-comp) DST bv2-count bv2-stride)
(define index-ok (check-dec bv2-gold))

(load! SRC bv0-comp)
(meshopt-vertex! SRC (llen bv0-comp) DST bv0-count bv0-stride)
(meshopt-filter-oct! DST bv0-count bv0-stride)
(define oct-ok (check-dec bv0-gold))

