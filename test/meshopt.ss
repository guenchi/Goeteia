(meshopt-index! SRC (llen fidx-comp) DST fidx-count fidx-stride)
(define fox-index-ok (check-dec fidx-gold))

(load! SRC exp-comp)
(meshopt-vertex! SRC (llen exp-comp) DST exp-count exp-stride)
(meshopt-filter-exp! DST exp-count exp-stride)
(define exp-ok
  (let loop ((g exp-gold) (i 0) (bad 0))
    (if (null? g)
        (< bad 4)
        (loop (cdr g) (+ i 1)
              (if (= (%mem-u8-ref (+ DST i)) (car g)) bad (+ bad 1))))))

(and vertex-ok index-ok oct-ok fox-index-ok exp-ok)
