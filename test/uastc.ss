;; expect: #t
;; (gfx uastc): UASTC LDR 4x4 -> RGBA, byte-for-byte against the basisu
;; transcoder's RGBA32 unpack across the modes its encoder emits.
(import (rnrs) (gfx uastc))

(let ((need (- 400000 (* 65536 (%mem-size)))))
  (when (> need 0) (%mem-grow (quotient (+ need 65535) 65536))))

(define SRC 50000)      ; 13 blocks * 16 bytes
(define DST 60000)      ; scratch for one decoded block (64 bytes)
(define (load! base bs)
  (let put ((b bs) (i 0))
    (when (pair? b) (%mem-u8-set! (+ base i) (car b)) (put (cdr b) (+ i 1)))))
(define (llen l) (let loop ((l l) (n 0)) (if (null? l) n (loop (cdr l) (+ n 1)))))
(define nblk 13)
(define blk-src
  (append
   (quote (177 72 3 96 221 214 109 221 98 251 97 251 96 250 80 233 245 36 254 179 239 179 239 179 79 78 78 78 14 0 0 0 83 129 6 248 199 53 228 247 255 223 255 161 42 213 127 0 235 129 30 113 16 113 16 113 128 70 177 85 253 245 7 0 219 129 2 5 5 8 48 128 64 200 81 217 98 234 115 251 247 255 255 255 31 124 239 1 0 0 0 0 0 0 0 0 207 168 3 177 28 254 1 66 222 225 1 34 0 165 254 115 202 216 177 81 35 160 0 0 0 0 32 83 48 167 80 250 56 49 18 32 1 8 129 197 49 48 116 116 184 184 252 252 95 1 32 81 88 154 64 2 32 96 88 26 5 165 175 15))
   (quote (5 5 90 71 116 250 255 255 110 95 110 63 76 29 40 25 21 38 173 227 254 129 254 255 91 138 254 255 203 228 228 228 229 252 186 67 225 255 255 159 153 1 152 1 128 1 0 0))))
(define blk-gold
  (append
   (quote (173 173 173 255 184 184 184 255 195 195 195 255 203 203 203 255 173 173 173 255 184 184 184 255 195 195 195 255 203 203 203 255 171 171 171 255 184 184 184 255 193 193 193 255 203 203 203 255 171 171 171 255 182 182 182 255 191 191 191 255 201 201 201 255 159 159 159 255 148 148 148 255 136 136 136 255 125 125 125 255 159 159 159 255 148 148 148 255 136 136 136 255 125 125 125 255 159 159 159 255 148 148 148 255 136 136 136 255 125 125 125 255 159 159 159 255 148 148 148 255 136 136 136 255 125 125 125 255 132 123 132 255 132 123 132 255 145 123 138 255 147 132 145 255 132 132 136 255 132 132 136 255 147 132 145 255 147 132 145 255))
   (quote (132 142 141 255 132 142 141 255 149 142 152 255 149 142 152 255 132 151 145 255 132 151 145 255 151 151 158 255 151 151 158 255 17 17 17 255 14 14 14 255 12 12 12 255 11 11 11 255 14 14 14 255 11 11 11 255 9 9 9 255 9 9 9 255 14 14 14 255 9 9 9 255 8 8 8 255 7 7 7 255 12 12 12 255 9 9 9 255 7 7 7 255 7 7 7 255 0 0 4 255 7 0 4 255 14 0 4 255 22 0 4 255 0 7 8 255 7 7 8 255 14 7 8 255 22 7 8 255 0 16 12 255 7 16 12 255 14 16 12 255 22 16 12 255 0 24 17 255 7 24 17 255 14 24 17 255 22 24 17 255))
   (quote (255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 255 0 0 17 255 0 0 17 255 0 0 17 255 0 0 17 250 84 0 17 250 84 0 17 244 171 0 17 244 171 0 17 244 171 0 17 238 255 0 17 238 255 0 17 160 255 0 22 238 255 0 17 160 255 0 22 78 255 0 28 0 255 0 34 255 0 0 5 255 0 0 5 255 0 0 5 255 0 0 5 255 0 0 5 255 27 0 5 255 40 0 6 255 71 0 6))
   (quote (255 0 0 5 255 40 0 6 255 98 0 7 255 146 0 9 255 0 0 5 255 71 0 6 255 146 0 9 255 217 0 11 0 16 0 255 0 32 0 201 0 16 0 255 0 32 0 201 0 16 15 255 0 32 15 201 0 16 15 255 0 32 15 201 0 16 32 255 0 32 32 201 0 16 32 255 0 32 32 201 0 16 48 255 0 32 48 201 0 16 48 255 0 32 48 201 97 2 128 97 97 2 128 97 105 2 128 105 105 2 128 105 97 2 128 97 97 2 128 97 105 2 128 105 105 2 128 105 97 9 128 97 97 9 128 97 105 9 128 105 105 9 128 105 97 9 128 97 97 9 128 97 105 9 128 105 105 9 128 105))
   (quote (214 214 214 255 220 220 220 255 227 227 227 255 233 233 233 255 212 212 212 255 220 220 220 255 227 227 227 255 233 233 233 255 211 211 211 255 219 219 219 255 226 226 226 255 232 232 232 255 209 209 209 255 216 216 216 255 224 224 224 255 229 229 229 255 127 127 127 255 138 138 138 255 150 150 150 255 162 162 162 255 127 127 127 255 138 138 138 255 149 149 149 255 162 162 162 255 127 127 127 255 138 138 138 255 149 149 149 255 162 162 162 255 127 127 127 255 138 138 138 255 149 149 149 255 160 160 160 255 10 10 10 255 255 255 255 255 255 255 255 255 255 255 255 255 10 10 10 255 10 10 10 255 255 255 255 255 255 255 255 255))
   (quote (10 10 10 255 10 10 10 255 10 10 10 255 255 255 255 255 10 10 10 255 10 10 10 255 10 10 10 255 10 10 10 255))))

(load! SRC blk-src)
(define (check)
  (let loop ((bi 0) (g blk-gold) (bad 0))
    (if (= bi nblk)
        (begin (when (> bad 0) (display "  ") (display bad) (display " texels differ") (newline))
               (= bad 0))
        (begin
          (uastc-block! (+ SRC (* bi 16)) DST)
          (let tx ((i 0) (g g) (bad bad))
            (if (= i 64)
                (loop (+ bi 1) g bad)
                (tx (+ i 1) (cdr g)
                    (if (= (%mem-u8-ref (+ DST i)) (car g)) bad (+ bad 1)))))))))
(display (check))
(newline)
