;; expect: #t
;; (gfx zstd): RFC 8878 decompression -- raw / RLE / compressed blocks,
;; Huffman literals and FSE sequences, golden against the zstd CLI.
(import (rnrs) (gfx zstd))

;; grow staging memory for the largest case
(let ((need (- 600000 (* 65536 (%mem-size)))))
  (when (> need 0) (%mem-grow (quotient (+ need 65535) 65536))))

(define SRC 100000)
(define DST 250000)
(define SCRATCH 450000)
(define (load! base bs)
  (let put ((b bs) (i 0))
    (when (pair? b) (%mem-u8-set! (+ base i) (car b)) (put (cdr b) (+ i 1)))))
(define (llen l) (let loop ((l l) (n 0)) (if (null? l) n (loop (cdr l) (+ n 1)))))
(define (check name comp gold plainlen)
  (load! SRC comp)
  (let ((n (zstd-decode! SRC (llen comp) DST SCRATCH)))
    (if (not (= n plainlen))
        (begin (display "  ") (display name) (display ": wrote ") (display n)
               (display " want ") (display plainlen) (newline) #f)
        (let loop ((g gold) (i 0) (bad 0))
          (if (null? g)
              (if (= bad 0) #t
                  (begin (display "  ") (display name) (display ": ")
                         (display bad) (display " bytes differ") (newline) #f))
              (loop (cdr g) (+ i 1)
                    (if (= (%mem-u8-ref (+ DST i)) (car g)) bad (+ bad 1))))))))

