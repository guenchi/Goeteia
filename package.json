{
  "name": "goeteia",
  "version": "1.5.0",
  "description": "A graphics-optimized Scheme-to-WASM compiler and pure-Scheme web programming toolkit.",
  "type": "module",
  "bin": {
    "goeteia": "bin/goeteia.mjs"
  },
  "scripts": {
    "dev": "node bin/goeteia.mjs dev",
    "build": "sh build.sh",
    "test": "sh run-tests.sh"
  },
  "exports": {
    ".": "./rt/run.mjs",
    "./compile": "./rt/compile.mjs",
    "./run": "./rt/run.mjs"
  },
  "files": [
    "goeteia.wasm",
    "bin/",
    "rt/",
    "lib/",
    "src/",
    "build.sh",
    "playground.html",
    "playground.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "scheme",
    "webassembly",
    "wasm",
    "wasm-gc",
    "compiler",
    "self-hosting",
    "r6rs",
    "lisp"
  ],
  "homepage": "https://goeteia.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guenchi/Goeteia.git"
  },
  "bugs": {
    "url": "https://github.com/guenchi/Goeteia/issues"
  },
  "author": "guenchi",
  "license": "MIT"
}
